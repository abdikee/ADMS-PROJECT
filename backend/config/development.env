# Development Environment Configuration
# Copy this file to .env and update with your actual values

# Database Configuration
DATABASE_URL=postgresql://dev_user:dev_pass@localhost:5432/sams_dev
REDIS_URL=redis://localhost:6379

# Security Configuration
JWT_SECRET=development_jwt_secret_at_least_32_characters_long
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Server Configuration
PORT=5000

# Monitoring Configuration
LOG_LEVEL=debug
ENABLE_METRICS=true
METRICS_PORT=9090

# Security Settings
ENABLE_RATE_LIMITING=false
ENABLE_SECURITY_HEADERS=true
SESSION_TIMEOUT=3600000

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx,xls,xlsx

# Development Features
ENABLE_SWAGGER=true
ENABLE_DEBUG_LOGS=true
ENABLE_PERFORMANCE_LOGS=true
ENABLE_SQL_LOGS=true

# Performance Configuration
DB_POOL_MIN=1
DB_POOL_MAX=3
REDIS_POOL_SIZE=3

# Testing Configuration
ENABLE_TEST_MODE=false
MOCK_EXTERNAL_APIS=true
