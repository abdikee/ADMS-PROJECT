# Staging Environment Configuration
# Copy this file to .env and update with your actual values

# Database Configuration
DATABASE_URL=postgresql://staging_user:staging_pass@localhost:5432/sams_staging
REDIS_URL=redis://localhost:6379

# Security Configuration
JWT_SECRET=staging_jwt_secret_at_least_32_characters_long
NODE_ENV=staging

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,https://staging.yourdomain.com

# Server Configuration
PORT=5000

# Backup Configuration
BACKUP_SCHEDULE=0 3 * * *
BACKUP_RETENTION_DAYS=7

# Monitoring Configuration
LOG_LEVEL=debug
ENABLE_METRICS=true
METRICS_PORT=9090

# Security Settings
ENABLE_RATE_LIMITING=true
ENABLE_SECURITY_HEADERS=true
SESSION_TIMEOUT=1800000

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf

# Performance Configuration
DB_POOL_MIN=1
DB_POOL_MAX=5
REDIS_POOL_SIZE=5

# Development Features
ENABLE_SWAGGER=true
ENABLE_DEBUG_LOGS=true
ENABLE_PERFORMANCE_LOGS=true
